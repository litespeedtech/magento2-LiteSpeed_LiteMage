<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\PageCache\Model\System\Config\Source\Application">
        <plugin name="pagecache-system-source-litemage" type="Litespeed\Litemage\Model\System\Config\Source\ApplicationPlugin" sortOrder="1"/>
    </type>
    <type name="\Magento\Framework\App\Response\Http">
        <plugin name="response-http-litemage-admpurge" type="\Litespeed\Litemage\Model\App\Response\HttpPurgePlugin" sortOrder="10"/>
    </type>
    <type name="Magento\Framework\View\Element\Message\MessageConfigurationsPool">
        <arguments>
            <argument name="configurationsMap" xsi:type="array">
                <item name="litemageWarmupSourcesChanged" xsi:type="array">
                    <item name="renderer" xsi:type="const">\Magento\Framework\View\Element\Message\Renderer\BlockRenderer::CODE</item>
                    <item name="data" xsi:type="array">
                        <item name="template" xsi:type="string">Litespeed_Litemage::messages/warmup_sources_changed.phtml</item>
                    </item>
                </item>
            </argument>
        </arguments>
    </type>
</config>
