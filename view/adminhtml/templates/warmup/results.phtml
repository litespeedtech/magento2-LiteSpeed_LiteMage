<script>
require([], function () {
    Array.prototype.forEach.call(document.querySelectorAll('.litemage-results-pager'), function (button) {
        button.addEventListener('click', function () {
            if (!button.disabled) {
                setLocation(button.getAttribute('data-url'));
            }
        });
    });

    Array.prototype.forEach.call(document.querySelectorAll('.litemage-grid-page-input'), function (input) {
        var goToPage = function () {
            var totalPages = parseInt(input.getAttribute('data-total-pages'), 10) || 1;
            var page = parseInt(input.value, 10) || 1;
            page = Math.max(1, Math.min(page, totalPages));
            input.value = page;

            var url = new URL(window.location.href);
            url.searchParams.set('page', page);
            setLocation(url.toString());
        };

        input.addEventListener('change', goToPage);
        input.addEventListener('keydown', function (event) {
            if (event.key === 'Enter') {
                event.preventDefault();
                goToPage();
            }
        });
    });
});
</script>
