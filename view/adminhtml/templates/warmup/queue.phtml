$duePending = (int)$actionCounts['due_pending'];
$staleRunning = (int)$actionCounts['stale_running'];
$disabledSourceRows = (int)$actionCounts['disabled_source'];
$actions = [
    [
        'label' => __('Build Queue'),
        'url' => $block->getGenerateUrl(),
        'note' => __('Adds or updates queued warmup URLs from selected sources and removes disabled scheduled-source work. The Queue Build cron usually does this daily. It does not crawl URLs; Queue Process cron or Run Queue Now processes due rows.'),
        'primary' => false,
        'disabled' => false,
        'disabled_note' => '',
    ],
    [
        'label' => $staleRunning > 0
            ? __('Run Queue Now (%1 due, %2 stalled)', $duePending, $staleRunning)
            : __('Run Queue Now (%1 due)', $duePending),
        'url' => $block->getProcessUrl(),
        'note' => __('Manually runs one queue pass now instead of waiting for cron. It recovers stalled running rows before claiming work and honors the same enabled state, load guard, batch size, concurrency, crawl delay, request timeout, max runtime, and lane locks as cron.'),
        'primary' => true,
        'disabled' => !$block->isWarmupEnabled() || ($duePending === 0 && $staleRunning === 0),
        'disabled_note' => !$block->isWarmupEnabled()
            ? __('Cache warmer is paused. Resume it before processing queued URLs.')
            : __('No pending queued URLs are due and no stalled running rows are waiting for recovery.'),
    ],
    [
        'label' => __('Retry Failed (%1)', (int)$actionCounts['failed']),
        'url' => $block->getRetryFailedUrl(),
        'note' => __('Moves failed queued URLs back to pending so the queue can try those rows again.'),
        'primary' => false,
        'disabled' => (int)$actionCounts['failed'] === 0,
        'disabled_note' => __('No failed queued URLs are available to retry.'),
    ],
];
if ($disabledSourceRows > 0) {
    $actions[] = [
        'label' => __('Clear Disabled Sources (%1)', $disabledSourceRows),
        'url' => $block->getClearDisabledSourcesUrl(),
        'note' => __('Removes durable scheduled queue rows and source memberships that still belong to disabled sources. Use this when you want to clean those rows immediately without rebuilding every enabled source.'),
        'primary' => false,
        'disabled' => false,
        'disabled_note' => '',
