<script>
require(['mage/translate'], function ($t) {
    var actionHelpText = document.getElementById('litemage-warmup-action-help-text');
    var executeButton = document.getElementById('litemage-warmup-action-execute');
    var executeButtonLabel = executeButton ? executeButton.querySelector('span') : null;
    var defaultActionHelp = $t('Select a queue action to review details, then run it.');
    var actionButtons = document.querySelectorAll('.litemage-warmup-action');
    var pagerButtons = document.querySelectorAll('.litemage-warmup-pager');
    var selectedAction = null;
    var selectedUrl = '';

    var renderActionHelp = function (message, label, url, executable) {
        if (actionHelpText) {
            actionHelpText.textContent = message || defaultActionHelp;
        }
        selectedUrl = executable ? url : '';
        if (executeButton) {
            executeButton.hidden = !executable;
            executeButton.disabled = !executable;
        }
        if (executeButtonLabel) {
            executeButtonLabel.textContent = label || '';
        }
    };

    var clearSelectedAction = function () {
        Array.prototype.forEach.call(actionButtons, function (button) {
            button.classList.remove('_selected');
            button.setAttribute('aria-pressed', 'false');
        });
    };

    Array.prototype.forEach.call(actionButtons, function (button) {
        var note = button.getAttribute('data-note') || defaultActionHelp;
        var disabledNote = button.getAttribute('data-disabled-note') || note;
        var label = button.getAttribute('data-label') || button.textContent;
        var url = button.getAttribute('data-url');

        button.addEventListener('click', function () {
            clearSelectedAction();
            selectedAction = button;
            button.classList.add('_selected');
            button.setAttribute('aria-pressed', 'true');
            if (button.getAttribute('aria-disabled') === 'true') {
                renderActionHelp(disabledNote, '', '', false);
                return;
            }
            renderActionHelp(note, label, url, true);
        });
        button.addEventListener('mouseenter', function () {
            renderActionHelp(button.getAttribute('aria-disabled') === 'true' ? disabledNote : note, '', '', false);
        });
        button.addEventListener('focus', function () {
            renderActionHelp(button.getAttribute('aria-disabled') === 'true' ? disabledNote : note, '', '', false);
        });
        button.addEventListener('mouseleave', function () {
            if (selectedAction) {
                renderActionHelp(
                    selectedAction.getAttribute('aria-disabled') === 'true'
                        ? (selectedAction.getAttribute('data-disabled-note') || selectedAction.getAttribute('data-note') || defaultActionHelp)
                        : (selectedAction.getAttribute('data-note') || defaultActionHelp),
                    selectedAction.getAttribute('data-label') || selectedAction.textContent,
                    selectedAction.getAttribute('data-url'),
                    selectedAction.getAttribute('aria-disabled') !== 'true'
                );
            } else {
                renderActionHelp(defaultActionHelp, '', '', false);
            }
        });
    });

    if (executeButton) {
        executeButton.addEventListener('click', function () {
            if (selectedUrl) {
                submitWarmupAction(selectedUrl);
            }
        });
    }

    Array.prototype.forEach.call(pagerButtons, function (button) {
        button.addEventListener('click', function () {
            if (!button.disabled) {
                setLocation(button.getAttribute('data-url'));
            }
        });
    });

    Array.prototype.forEach.call(document.querySelectorAll('.litemage-grid-page-input'), function (input) {
        var goToPage = function () {
            var totalPages = parseInt(input.getAttribute('data-total-pages'), 10) || 1;
            var page = parseInt(input.value, 10) || 1;
            page = Math.max(1, Math.min(page, totalPages));
            input.value = page;

            var url = new URL(window.location.href);
            url.searchParams.set('page', page);
            setLocation(url.toString());
        };

        input.addEventListener('change', goToPage);
        input.addEventListener('keydown', function (event) {
            if (event.key === 'Enter') {
                event.preventDefault();
                goToPage();
            }
        });
    });

    window.litemageWarmupConfirmMassAction = function (form) {
        var action = form.querySelector('[name="mass_action"]').value;
        var selected = form.querySelectorAll('.litemage-warmup-row:checked').length;
        var messages = {
            blacklist: $t('Blacklist selected URLs? Blacklisted URLs will be skipped by future warmup generation.'),
            unblacklist: $t('Remove selected URLs from the blacklist? Future queue builds may add them again.'),
            warm: $t('Warm selected URLs now? This sends crawler requests immediately.'),
            curl: $t('Show cURL commands for selected URLs? This does not warm the cache.')
        };

        if (!action) {
            alert($t('Choose a selected-row action first.'));
            return false;
        }
        if (!selected) {
            alert($t('Select one or more queued URL rows first.'));
            return false;
        }
        return confirm(messages[action] || $t('Apply the selected action now?'));
    };

    function submitWarmupAction(url) {
        var form = document.getElementById('litemage-warmup-action-post');
        if (!form || !url) {
            return;
        }
        form.setAttribute('action', url);
        form.submit();
    }
});
</script>
