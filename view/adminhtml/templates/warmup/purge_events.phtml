<script>
require(['jquery'], function ($) {
    $('.litemage-purge-events-toggle').on('click', function () {
        var button = $(this);
        var text = button.siblings('.litemage-purge-events-text').first();
        var expanded = text.hasClass('is-expanded');

        text.toggleClass('is-expanded', !expanded);
        button.text(expanded ? button.data('expand-label') : button.data('collapse-label'));
    });

    $('.litemage-purge-events-pager').on('click', function () {
        if (!this.disabled) {
            setLocation($(this).data('url'));
        }
    });

    $('.litemage-grid-page-input').on('change keydown', function (event) {
        if (event.type === 'keydown' && event.key !== 'Enter') {
            return;
        }
        if (event.type === 'keydown') {
            event.preventDefault();
        }

        var totalPages = parseInt(this.getAttribute('data-total-pages'), 10) || 1;
        var page = parseInt(this.value, 10) || 1;
        page = Math.max(1, Math.min(page, totalPages));
        this.value = page;

        var url = new URL(window.location.href);
        url.searchParams.set('page', page);
        setLocation(url.toString());
    });
});
</script>
