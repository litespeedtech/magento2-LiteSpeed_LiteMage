<script>
require(['jquery'], function ($) {
    $('.litemage-progress-state-action').on('click', function () {
        if (confirm($(this).attr('data-confirm'))) {
            $('#litemage-progress-runner-action').trigger('submit');
        }
    });

    $('.litemage-progress-toggle').on('click', function () {
        var button = $(this);
        var group = button.data('target');
        var expanded = button.attr('aria-expanded') === 'true';

        $('.litemage-progress-lane-row[data-group="' + group + '"]').toggleClass('_hidden', expanded);
        button.attr('aria-expanded', expanded ? 'false' : 'true');
        button.text(expanded ? button.data('expand-label') : button.data('collapse-label'));
    });
});
</script>
