<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Litespeed_Litemage::css/warmup-progress.css"/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Litespeed\Litemage\Block\Adminhtml\Warmup\Progress" name="litemage.warmup.progress">
                <arguments>
                    <argument name="active_section" xsi:type="string">progress</argument>
                </arguments>
                <block class="Litespeed\Litemage\Block\Adminhtml\Warmup\Navigation" name="litemage.warmup.navigation" as="litemage.warmup.navigation">
                    <arguments>
                        <argument name="active_section" xsi:type="string">progress</argument>
                    </arguments>
                </block>
            </block>
        </referenceContainer>
    </body>
</page>
